  "rules": [
    {
      "name": "criticalChildInfluencesParent",
      "description": "A critical child concept structurally influences its parent.",
      "swrl": "hasSubAspect(?parent, ?child) ^ isCritical(?child, true) -> influences(?child, ?parent)",
      "executable_in_owl": true
    },
    {
      "name": "criticalNegativeHasHighImpact",
      "description": "A critical concept with a negative model score has high impact.",
      "swrl": "Operational numeric rule evaluated after sentiment prediction; HermiT does not support the required swrlb:lessThan atom.",
      "executable_in_owl": false
    },
    {
      "name": "allObservedChildrenNegative",
      "description": "When every observed child is negative, the parent should not be positive. Closed-world evaluation is required.",
      "swrl": "Operational closed-world rule; not representable faithfully as a plain OWL 2 DL/SWRL universal quantification.",
      "executable_in_owl": false
    },
    {
      "name": "contradictoryConceptSeparation",
      "description": "Concepts linked by contradicts should not receive nearly equal sentiment scores.",
      "swrl": "Operational numeric rule evaluated by the training constraint layer.",
      "executable_in_owl": false
    }
  ]
}
