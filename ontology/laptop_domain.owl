<owl:NamedIndividual rdf:about="#criticalChildInfluencesParent">
  <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#hasSubAspect"/>
          <swrl:argument1 rdf:resource="urn:swrl#parent"/>
          <swrl:argument2 rdf:resource="urn:swrl#child"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:DatavaluedPropertyAtom>
              <swrl:propertyPredicate rdf:resource="#isCritical"/>
              <swrl:argument1 rdf:resource="urn:swrl#child"/>
              <swrl:argument2 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrl:argument2>
            </swrl:DatavaluedPropertyAtom>
          </rdf:first>
          <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#influences"/>
          <swrl:argument1 rdf:resource="urn:swrl#child"/>
          <swrl:argument2 rdf:resource="urn:swrl#parent"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</owl:NamedIndividual>

<swrl:Variable rdf:about="urn:swrl#parent"/>

<swrl:Variable rdf:about="urn:swrl#child"/>

